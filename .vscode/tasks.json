{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run AeroGuard",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/uvicorn backend.main:app --host 127.0.0.1 --port 8000 --reload",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/pytest tests -v",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Docker up",
      "type": "shell",
      "command": "docker compose up --build",
      "problemMatcher": []
    }
  ]
}
