# AeroGuard configuration (copy to .env and edit)
# SECURITY: set a strong random key in any real deployment.
AEROGUARD_API_KEY=change-me-to-a-long-random-value
AEROGUARD_HOST=127.0.0.1
AEROGUARD_PORT=8000
AEROGUARD_DB_PATH=data/aeroguard.db
# Sized for ~8 fps live webcam pose streaming per client.
AEROGUARD_RATE_LIMIT_PER_MINUTE=900
AEROGUARD_LOG_LEVEL=INFO
